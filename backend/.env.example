PORT=5001
MONGODB_URI=mongodb://localhost:27017/contractportal
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:5173

# Storage: local | s3 | cloudinary | minio
STORAGE_PROVIDER=local
UPLOAD_DIR=uploads

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=contracts
MINIO_USE_SSL=false

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Contract Portal <noreply@contractportal.com>

# OCR
# OCR_PROVIDER: hybrid | openai | tesseract
OCR_PROVIDER=hybrid
OCR_LANG=vie+eng
OCR_IMAGE_WIDTH=1800
OCR_MAX_PDF_PAGES=5
OCR_MIN_CONFIDENCE=65
OCR_MIN_TEXT_LENGTH=30
OCR_OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
